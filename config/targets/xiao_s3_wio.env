TARGET_NAME="xiao_s3_wio"
TARGET_READY=1

PIO_ENV="Xiao_S3_WIO_repeater"
VARIANT_PLATFORMIO_PATH="variants/xiao_s3_wio/platformio.ini"

UPLOAD_CHIP="esp32s3"
UPLOAD_BAUD=460800

# First existing device node is used when UPLOAD_PORT is not set.
UPLOAD_PORT_CANDIDATES="/dev/cu.usbmodem* /dev/ttyACM* /dev/cu.SLAB_USBtoUART*"
