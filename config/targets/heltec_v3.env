TARGET_NAME="heltec_v3"
TARGET_READY=1

# Validated against upstream variants/heltec_v3/platformio.ini.
PIO_ENV="Heltec_v3_repeater"
VARIANT_PLATFORMIO_PATH="variants/heltec_v3/platformio.ini"

UPLOAD_CHIP="esp32s3"
UPLOAD_BAUD=460800
UPLOAD_PORT_CANDIDATES="/dev/cu.usbmodem* /dev/ttyACM* /dev/cu.SLAB_USBtoUART*"
