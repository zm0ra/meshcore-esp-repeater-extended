# Copy this file to config/local.env (gitignored).
# This file overrides config/base.env and selected target profile values.
# Keep only compile-time bootstrap and secrets here.
# Runtime node/radio/security values are edited in the web panel.

# ---------- Required bootstrap ----------
# Required for web UI + TCP services to be reachable after boot.
WIFI_SSID="your_wifi_ssid"
WIFI_PASSWORD="your_wifi_password"

# ---------- Optional bootstrap overrides ----------
# TCP_PORT=5002
# CONSOLE_PORT=5001
# CONSOLE_MIRROR_PORT=5003
# HTTP_STATS_PORT=80

# ---------- Optional HTTP limits ----------
# HTTP_MAX_CLIENTS=4
# HTTP_MAX_HEADER_BYTES=6144
# HTTP_MAX_BODY_BYTES=12288
# HTTP_CLIENT_TIMEOUT_MS=2500
# HTTP_READ_BUDGET_PER_LOOP=768

# ---------- Optional diagnostics ----------
# WIFI_DEBUG_LOGGING=1
# MESH_PACKET_LOGGING=1
# MESH_DEBUG=0
# BRIDGE_DEBUG=0
# BLE_DEBUG_LOGGING=0

# ---------- MQTT compile bootstrap ----------
# MQTT is disabled by default. Enable only when broker profile(s) are configured.
# MQTT_REPORTING_ENABLED=1
# MQTT_MAX_ACTIVE_BROKERS=4
# MQTT_IATA="ABC"

# Optional topic templates (placeholders: {IATA}, {PUBLIC_KEY}):
# MQTT_TOPIC_STATUS="meshcore/{IATA}/{PUBLIC_KEY}/status"
# MQTT_TOPIC_PACKETS="meshcore/{IATA}/{PUBLIC_KEY}/packets"
# MQTT_TOPIC_RAW="meshcore/{IATA}/{PUBLIC_KEY}/raw"

# LetsMesh built-in profiles (enable explicitly when needed):
# MQTT_LETSMESH_US_ENABLED=1
# MQTT_LETSMESH_US_AUTH_METHOD="token"
# MQTT_LETSMESH_EU_ENABLED=1
# MQTT_LETSMESH_EU_AUTH_METHOD="token"

# Custom extra profile (all required fields below when enabled):
# MQTT_EXTRA_ENABLED=1
# MQTT_EXTRA_NAME="custom"
# MQTT_EXTRA_HOST="mqtt.example.net"
# MQTT_EXTRA_PORT=1883
# MQTT_EXTRA_KEEPALIVE=60
# MQTT_EXTRA_TRANSPORT="tcp"      # tcp|websockets
# MQTT_EXTRA_WS_PATH="/"          # used for websockets
# MQTT_EXTRA_TLS_ENABLED=0
# MQTT_EXTRA_TLS_VERIFY=1
# MQTT_EXTRA_AUTH_METHOD="password"
# MQTT_EXTRA_USERNAME="mqtt_user"
# MQTT_EXTRA_PASSWORD="mqtt_password"
# MQTT_EXTRA_CLIENT_ID=""
# MQTT_EXTRA_AUDIENCE=""
# MQTT_EXTRA_OWNER=""
# MQTT_EXTRA_EMAIL=""

# Legacy single custom profile (optional; prefer MQTT_EXTRA_*):
# MQTT_HOST="mqtt.example.net"
# MQTT_PORT=1883
# MQTT_KEEPALIVE=60
# MQTT_TRANSPORT="tcp"
# MQTT_WS_PATH="/"
# MQTT_TLS_ENABLED=0
# MQTT_TLS_VERIFY=1
# MQTT_AUTH_METHOD="none"
# MQTT_USERNAME=""
# MQTT_PASSWORD=""
# MQTT_CLIENT_ID=""
# MQTT_AUDIENCE=""
# MQTT_OWNER=""
# MQTT_EMAIL=""

# ---------- Optional upload defaults ----------
# UPLOAD_PORT="/dev/cu.usbmodem1101"
# UPLOAD_BAUD=460800
# MONITOR_BAUD=115200
