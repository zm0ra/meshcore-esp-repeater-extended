# Global defaults for repeater overlay builds.
# Load order:
#   1) config/base.env
#   2) config/targets/<target>.env (unless --pio-env is used)
#   3) config/local.env (optional developer override; gitignored)

# ---------- Upstream source ----------
UPSTREAM_REPO_URL="https://github.com/meshcore-dev/MeshCore.git"
UPSTREAM_REPO_BRANCH="main"

# Optional esptool fallback (used only if esptool/esptool.py is not in PATH)
ESPTOOL_REPO_URL="https://github.com/espressif/esptool.git"
ESPTOOL_REPO_REF="master"

# ---------- Build identity ----------
WORK_DIR="./build"
BUILD_ROLE="repeater"
# auto-extended: detect upstream FIRMWARE_VERSION and append "-extended" during build
FIRMWARE_VERSION="auto-extended"

# ---------- Compile-time bootstrap (required in firmware image) ----------
# WiFi and TCP/HTTP ports are startup bootstrap values required before web UI
# configuration is reachable.
WIFI_SSID="mesh_ssid"
WIFI_PASSWORD="mesh_password"
TCP_PORT=5002
CONSOLE_PORT=5001
CONSOLE_MIRROR_PORT=5003
HTTP_STATS_PORT=80

# HTTP server resource limits (keep conservative for ESP32 RAM)
HTTP_MAX_CLIENTS=4
HTTP_MAX_HEADER_BYTES=6144
HTTP_MAX_BODY_BYTES=12288
HTTP_CLIENT_TIMEOUT_MS=2500
HTTP_READ_BUDGET_PER_LOOP=768

# ---------- Compile-time diagnostics ----------
WIFI_DEBUG_LOGGING=1
MESH_PACKET_LOGGING=1
MESH_DEBUG=0
BRIDGE_DEBUG=0
BLE_DEBUG_LOGGING=0

# ---------- MQTT compile bootstrap ----------
# MQTT in this overlay is publish-only.
# Node identity/radio/security are runtime-managed in web panel.
MQTT_REPORTING_ENABLED=0
MQTT_MAX_ACTIVE_BROKERS=4
MQTT_IATA="XXX"

# Topic templates:
#   {IATA}       -> uppercased 3-letter IATA code
#   {PUBLIC_KEY} -> node public key hex
MQTT_TOPIC_STATUS="meshcore/{IATA}/{PUBLIC_KEY}/status"
MQTT_TOPIC_PACKETS="meshcore/{IATA}/{PUBLIC_KEY}/packets"
MQTT_TOPIC_RAW="meshcore/{IATA}/{PUBLIC_KEY}/raw"

# Built-in LetsMesh profiles (enable explicitly in local env or CLI)
MQTT_LETSMESH_US_ENABLED=0
MQTT_LETSMESH_US_AUTH_METHOD="token"
MQTT_LETSMESH_EU_ENABLED=0
MQTT_LETSMESH_EU_AUTH_METHOD="token"

# Optional third broker profile (disabled by default).
# Keep host/credentials in config/local.env (never commit secrets).
MQTT_EXTRA_ENABLED=0
# MQTT_EXTRA_NAME="custom"
# MQTT_EXTRA_HOST="mqtt.example.net"
# MQTT_EXTRA_PORT=1883
# MQTT_EXTRA_KEEPALIVE=60
# MQTT_EXTRA_TRANSPORT="tcp"
# MQTT_EXTRA_WS_PATH="/"
# MQTT_EXTRA_TLS_ENABLED=0
# MQTT_EXTRA_TLS_VERIFY=1
# MQTT_EXTRA_AUTH_METHOD="password"
# MQTT_EXTRA_USERNAME="mqtt_user"
# MQTT_EXTRA_PASSWORD="mqtt_password"
# MQTT_EXTRA_CLIENT_ID=""
# MQTT_EXTRA_AUDIENCE=""
# MQTT_EXTRA_OWNER=""
# MQTT_EXTRA_EMAIL=""

# Legacy single custom broker profile (optional; prefer MQTT_EXTRA_* above):
# MQTT_HOST="mqtt.example.net"
# MQTT_PORT=1883
# MQTT_KEEPALIVE=60
# MQTT_TRANSPORT="tcp"
# MQTT_WS_PATH="/"
# MQTT_TLS_ENABLED=0
# MQTT_TLS_VERIFY=1
# MQTT_AUTH_METHOD="none"
# MQTT_USERNAME=""
# MQTT_PASSWORD=""
# MQTT_CLIENT_ID=""
# MQTT_AUDIENCE=""
# MQTT_OWNER=""
# MQTT_EMAIL=""
